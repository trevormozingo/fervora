{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CreateProfile",
  "description": "Schema for creating a new profile. Server generates id, timestamps, and defaults.",
  "x-api": [
    { "method": "POST", "path": "/profiles", "description": "Create profile for authenticated user" }
  ],
  "type": "object",
  "properties": {
    "username": {
      "$ref": "base.schema.json#/properties/username"
    },
    "displayName": {
      "$ref": "base.schema.json#/properties/displayName"
    },
    "profilePhoto": {
      "type": "string",
      "format": "uri",
      "description": "URL to the user's profile photo in Firebase Storage"
    },
    "birthday": {
      "type": "string",
      "format": "date",
      "description": "User's date of birth (YYYY-MM-DD)"
    },
    "bio": {
      "$ref": "base.schema.json#/properties/bio"
    },
    "location": {
      "$ref": "base.schema.json#/properties/location"
    },
    "interests": {
      "$ref": "base.schema.json#/properties/interests"
    },
    "fitnessLevel": {
      "$ref": "base.schema.json#/properties/fitnessLevel"
    }
  },
  "required": ["username", "displayName", "profilePhoto", "birthday"],
  "additionalProperties": false
}
