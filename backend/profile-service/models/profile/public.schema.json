{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PublicProfile",
  "description": "Public-facing profile view. Excludes sensitive fields.",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "base.schema.json#/properties/id"
    },
    "username": {
      "$ref": "base.schema.json#/properties/username"
    },
    "displayName": {
      "$ref": "base.schema.json#/properties/displayName"
    },
    "bio": {
      "$ref": "base.schema.json#/properties/bio"
    },
    "birthday": {
      "$ref": "base.schema.json#/properties/birthday"
    },
    "profilePhoto": {
      "$ref": "base.schema.json#/properties/profilePhoto"
    },
    "location": {
      "$ref": "base.schema.json#/properties/location"
    },
    "interests": {
      "$ref": "base.schema.json#/properties/interests"
    },
    "fitnessLevel": {
      "$ref": "base.schema.json#/properties/fitnessLevel"
    },
    "followersCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of users who follow this profile"
    },
    "followingCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of users this profile follows"
    },
    "postCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of posts by this user"
    },
    "isFollowing": {
      "type": "boolean",
      "description": "Whether the authenticated viewer follows this profile (only present when authenticated)"
    }
  },
  "required": ["id", "username", "displayName"],
  "additionalProperties": false
}
