{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BaseProfile",
  "description": "Base profile schema containing all profile fields",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Firebase user ID"
    },
    "username": {
      "type": "string",
      "minLength": 3,
      "maxLength": 30,
      "pattern": "^[a-zA-Z0-9_-]+$",
      "description": "Unique username (alphanumeric, underscores, hyphens)"
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "User's display name"
    },
    "bio": {
      "type": ["string", "null"],
      "maxLength": 500,
      "default": null,
      "description": "Short biography"
    },
    "birthday": {
      "type": ["string", "null"],
      "format": "date",
      "default": null,
      "description": "User's date of birth (YYYY-MM-DD)"
    },
    "profilePhoto": {
      "type": ["string", "null"],
      "format": "uri",
      "default": null,
      "description": "URL to the user's profile photo in Firebase Storage"
    },
    "location": {
      "type": ["object", "null"],
      "default": null,
      "description": "User's geolocation for nearby search",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["Point"],
          "default": "Point"
        },
        "coordinates": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2,
          "description": "[longitude, latitude]"
        },
        "label": {
          "type": ["string", "null"],
          "description": "Human-readable location name (e.g. city)"
        }
      },
      "required": ["type", "coordinates"]
    }
  },
  "additionalProperties": false
}
